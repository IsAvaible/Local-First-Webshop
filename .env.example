# Database connection URL for PostgreSQL
# This should match the database configuration in docker-compose.yaml
DATABASE_URL=postgresql://postgres:password@localhost:54321/electric

# Authentication secret - REQUIRED in production
# Generate a strong secret (minimum 32 characters)
BETTER_AUTH_SECRET=

# Stripe Secrets
# This is the public secret key used in the frontend
VITE_STRIPE_PUBLISHABLE_KEY=""
# This is the secret key used in the backend
STRIPE_SECRET_KEY=""
# This is the webhook secret used to verify Stripe webhooks. In local development, run "stripe:listen" to get this value.
STRIPE_WEBHOOK_SECRET=""