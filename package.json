{
  "name": "local-first-webshop",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "docker compose up -d && vite dev",
    "build": "vite build && tsx src/scripts/inject-manifest.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:generate": "drizzle-kit generate",
    "stripe:listen": "stripe listen --forward-to http://localhost:5173/api/stripe-webhook",
    "format": "prettier --write . --ignore-unknown",
    "lint": "eslint .",
    "wake-tunnel": "wait-on http-get://localhost:4173 && node -e \"fetch('http://localhost:4173').catch(()=>{})\"",
    "preview": "docker compose up -d && concurrently -n vite,wake -c blue,gray \"vite preview\" \"pnpm wake-tunnel\"",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:baseline": "cross-env TEST_PROFILE=baseline playwright test",
    "test:e2e:commuter": "cross-env TEST_PROFILE=commuter playwright test",
    "test:e2e:budget": "cross-env TEST_PROFILE=budget playwright test",
    "test:e2e:worst": "cross-env TEST_PROFILE=worst-case playwright test",
    "test:e2e:merge-results": "tsx tests/scripts/merge-results.ts",
    "prepare": "husky"
  },
